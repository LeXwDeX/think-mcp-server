{
  "name": "think-mcp-tool",
  "version": "1.0.1",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "think-mcp-tool": "dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npx tsx src/server.ts",
    "inspect": "npx fastmcp inspect src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "ai", "claude", "think-tool", "model-context-protocol", "reasoning"],
  "author": "LeXwDeX",
  "license": "MIT",
  "description": "An MCP server that provides a 'think' tool for structured reasoning, based on Anthropic's engineering research",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeXwDeX/think-mcp-server.git"
  },
  "homepage": "https://github.com/LeXwDeX/think-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/LeXwDeX/think-mcp-server/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fastmcp": "^4.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2"
  }
}